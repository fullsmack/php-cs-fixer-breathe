{
    "name": "fullsmack/php-cs-fixer-breathe",
    "description": "Breathe - Custom PHP-CS-Fixer configuration with FullSmack coding standards",
    "type": "library",
    "keywords": [
        "php-cs-fixer",
        "coding-standards",
        "code-style",
        "fixer",
        "ruleset",
        "breathe"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Nicolai Baaring"
        }
    ],
    "require": {
        "php": "^8.1",
        "friendsofphp/php-cs-fixer": "^3.92"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "FullSmack\\PhpCsFixerBreathe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FullSmack\\PhpCsFixerBreathe\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
